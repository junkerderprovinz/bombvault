; typescript-eslint's peer range is ">=4.8.4 <6.1.0", but this project's real
; compiler is the native `typescript` 7 (tsgo) devDep, so strict peer
; resolution can never succeed and npm overrides cannot nest a peer over a
; root direct dependency. The TS 6 JS API that typescript-eslint actually
; uses at runtime is provided side-by-side via the lint-ts/ sub-package
; (see eslint.config.js), exactly as the typescript-eslint TS 7 error
; message prescribes.
legacy-peer-deps=true
