# =============================================================================
# BombVault configuration — copy to .env and fill in.
# =============================================================================

# REQUIRED. AES-256-GCM master key for all secrets at rest (credentials + restic
# repo passwords). EXACTLY 64 lowercase hex chars (32 bytes). Generate with:
#   openssl rand -hex 32
# Losing/rotating this makes stored secrets and existing sessions unrecoverable.
APP_KEY=

# Storage. DATA_DIR = bulk data (local restic repos, self-signed certs).
# CONFIG_DIR = the small SQLite DB; defaults to DATA_DIR if unset.
DATA_DIR=/data
CONFIG_DIR=/config

# Ports. HTTPS is the default (self-signed cert auto-generated on first start).
PORT=3000
HTTPS_PORT=3443
# Set HTTP_ONLY=true to serve plain HTTP (e.g. behind a TLS-terminating proxy).
# NOTE: when HTTP_ONLY=true the session cookie's `secure` flag is also disabled,
# so the browser does not silently drop it over plain HTTP.
HTTP_ONLY=false

# Host appdata path probed by the spike and used for container backups.
APPDATA_DIR=/mnt/user/appdata

# Unraid flash directory that holds container template XML files.
# Default matches the Unraid Appdata Backup plugin convention.
# The flash dir must be mounted (read-write) for container-definition capture and restore.
FLASH_TEMPLATES_DIR=/boot/config/plugins/dockerMan/templates-user

# =============================================================================
# REQUIRED HOST MOUNTS (set in docker-compose.yml / the Unraid template)
# -----------------------------------------------------------------------------
# WARNING: these grant root-equivalent control of the host. Mount only what you
# need; prefer read-only where possible. This mirrors the access the Unraid
# Appdata Backup plugin already has.
#
#   /var/run/docker.sock           -> list/stop/start/create containers
#   /var/run/libvirt/libvirt-sock  -> manage KVM/libvirt VMs (virsh)
#   /mnt/user/appdata              -> container app-data (backup source)
#   /mnt/user/domains              -> VM vdisks (backup source)
#   /boot (read-only)              -> Unraid flash config + container templates
# =============================================================================
